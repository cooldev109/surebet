# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./surebet.db

# ── Scraping intervals ───────────────────────────────────────────────────────
SCRAPE_INTERVAL=30
ALERT_THRESHOLD=0.01
NEAR_SUREBET_THRESHOLD=1.05

# ── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-secret-key-in-production

# ── Dashboard Authentication ─────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-password
TOKEN_TTL_HOURS=24

# ── Bookmaker Credentials ─────────────────────────────────────────────────────
BETCRIS_USERNAME=your_betcris_user
BETCRIS_PASSWORD=your_betcris_password
BETCRIS_URL=https://be.betcris.do

JUANCITO_USERNAME=your_juancito_user
JUANCITO_PASSWORD=your_juancito_password
JUANCITO_URL=https://www.juancitosport.com.do

HDLINEA_URL=http://hdlinea.com.do

# ── Proxy (needed for Betcris geo-block) ─────────────────────────────────────
# Format: http://username:password@host:port
# Leave empty to connect directly
PROXY_URL=

# ── Email Alerts (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ── Telegram Alerts ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NEAR_SUREBETS=false
